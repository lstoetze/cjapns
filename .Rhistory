"uuid", "question", "concept", "choice",
"asylzeugnis", "geschlecht", "herkunftsland",
"alter", "fruehere_beschaeftigung", "schutzbeduerftigkeit",
"migrationsgrund", "religion", "sprachkenntnisse",
grep("^rank", names(cnj_dat_choice), value = TRUE)
)]
names(conjoint_df)[c(1:3)] <- c("respondent_id", "task_id", "profile_id")
conjoint_df$chosen <- as.numeric(conjoint_df$choice)
######################################################################
# Check for multivalued attributes
######################################################################
# Step 1: preprocess once per dataset
rank_spec <- list(
asylzeugnis = list(
rank_cols = c(
"Keine Unstimmigkeiten"     = "rank_asyltestr1",
"Geringe Unstimmigkeiten"   = "rank_asyltestr2",
"Groessere Unstimmigkeiten" = "rank_asyltestr3"
)
),
geschlecht = list(
rank_cols = c(
"Weiblich"  = "rank_genderr1",
"Maennlich" = "rank_genderr2"
)
),
herkunftsland = list(
rank_cols = c(
"Syrien"      = "rank_countryr1",
"Afghanistan" = "rank_countryr2",
"Kosovo"      = "rank_countryr3",
"Eritrea"     = "rank_countryr4",
"Pakistan"    = "rank_countryr5",
"Ukraine"     = "rank_countryr6",
"Irak"        = "rank_countryr7"
)
),
alter = list(
rank_cols = c(
"21 Jahre" = "rank_ager1",
"38 Jahre" = "rank_ager2",
"62 Jahre" = "rank_ager3"
)
),
fruehere_beschaeftigung = list(
rank_cols = c(
"Arbeitslos"      = "rank_occur1",
"Reinigungskraft" = "rank_occur2",
"Landwirt/in"     = "rank_occur3",
"Buchhalter/in"   = "rank_occur4",
"Lehrer/in"       = "rank_occur5",
"Arzt/Aerztin"    = "rank_occur6"
)
),
schutzbeduerftigkeit = list(
rank_cols = c(
"Keine"                                      = "rank_vulnerr1",
"Posttraumatische Belastungsstoerung (PTBS)" = "rank_vulnerr2",
"Folteropfer"                                = "rank_vulnerr3",
"Keine ueberlebenden Familienmitglieder"     = "rank_vulnerr4",
"Koerperlich behindert"                      = "rank_vulnerr5"
)
),
migrationsgrund = list(
rank_cols = c(
"Verfolgung wegen politischer Ansichten"            = "rank_migreasonr1",
"Verfolgung wegen religioeser Ueberzeugungen"       = "rank_migreasonr2",
"Verfolgung wegen ethnischer Zugehoerigkeit"        = "rank_migreasonr3",
"Suche nach besseren wirtschaftlichen Moeglichkeiten" = "rank_migreasonr4"
)
),
religion = list(
rank_cols = c(
"Christlich" = "rank_relir1",
"Agnostisch" = "rank_relir2",
"Muslim"     = "rank_relir3"
)
),
sprachkenntnisse = list(
rank_cols = c(
"Spricht fliessend Deutsch" = "rank_languager1",
"Spricht gebrochen Deutsch" = "rank_languager2",
"Spricht kein Deutsch"      = "rank_languager3"
)
)
)
pref_dat <- tidy_ranking_data(
data      = conjoint_df[!duplicated(conjoint_df$respondent_id), ],
id        = ~ respondent_id,
rank_spec = rank_spec
)
pref_dat   # inspect: shows mean rank per level per attribute
# Step 2: make preferences
prefs <- make_preferences(pref_dat, id = ~ respondent_id, type = "ranking")
# Step 3: estimate
res <- cj_apns(
chosen ~ asylzeugnis + geschlecht + ...,
data        = conjoint_df,
id          = ~ respondent_id,
assumption  = "both",
preferences = prefs,
se          = "parametric",
B           = 500
)
# Step 3: estimate
