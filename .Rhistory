alter = list(
conjoint_col = "alter",
levels = c(
"1" = "21 Jahre",
"2" = "38 Jahre",
"3" = "62 Jahre"
),
rank_prefix = "rank_ager"
),
fruehere_beschaeftigung = list(
conjoint_col = "fruehere_beschaeftigung",
levels = c(
"1" = "Arbeitslos",
"2" = "Reinigungskraft",
"3" = "Landwirt/in",
"4" = "Buchhalter/in",
"5" = "Lehrer/in",
"6" = "Arzt/Aerztin"
),
rank_prefix = "rank_occur"
),
schutzbeduerftigkeit = list(
conjoint_col = "schutzbeduerftigkeit",
levels = c(
"1" = "Keine",
"2" = "Posttraumatische Belastungsstoerung (PTBS)",
"3" = "Folteropfer",
"4" = "Keine ueberlebenden Familienmitglieder",
"5" = "Koerperlich behindert"
),
rank_prefix = "rank_vulnerr"
),
migrationsgrund = list(
conjoint_col = "migrationsgrund",
levels = c(
"1" = "Verfolgung wegen politischer Ansichten",
"2" = "Verfolgung wegen religioeser Ueberzeugungen",
"3" = "Verfolgung wegen ethnischer Zugehoerigkeit",
"4" = "Suche nach besseren wirtschaftlichen Moeglichkeiten"
),
rank_prefix = "rank_migreasonr"
),
religion = list(
conjoint_col = "religion",
levels = c(
"1" = "Christlich",
"2" = "Agnostisch",
"3" = "Muslim"
),
rank_prefix = "rank_relir"
),
sprachkenntnisse = list(
conjoint_col = "sprachkenntnisse",
levels = c(
"1" = "Spricht fliessend Deutsch",
"2" = "Spricht gebrochen Deutsch",
"3" = "Spricht kein Deutsch"
),
rank_prefix = "rank_languager"
)
)
# =============================================================================
# 11. RUN
# =============================================================================
results <- estimate_apns(
data      = conjoint_df,   # your long-format data frame
outcome   = "chosen",      # your binary 0/1 outcome column name
attr_spec = attr_spec,
bootstrap = FALSE,
B         = 1000,
alpha     = 0.05
)
# Attribute-level EAPNS with 95% bootstrap CIs, both assumptions:
results$eapns
library("devtools")
# load new version of package
setwd("~/Desktop/cjapns/")  # point to your project folder
devtools::load_all()
# Prepare conjoint data
cnj_dat_choice <- read.csv("~/Dropbox/Conjoint_Lukas/survey/data/conjoint_cleaned.csv")
# Build analysis dataset
conjoint_df <- cnj_dat_choice[, c(
"uuid", "question", "concept", "choice",
"asylzeugnis", "geschlecht", "herkunftsland",
"alter", "fruehere_beschaeftigung", "schutzbeduerftigkeit",
"migrationsgrund", "religion", "sprachkenntnisse",
grep("^rank", names(cnj_dat_choice), value = TRUE)
)]
names(conjoint_df)[c(1:3)] <- c("respondent_id", "task_id", "profile_id")
conjoint_df$chosen <- as.numeric(conjoint_df$choice)
######################################################################
# Check for multivalued attributes: Lukas's version vs. my version
######################################################################
# ── 1. Prepare preference data (one row per respondent) ──────────────
pref_dat <- conjoint_df[!duplicated(conjoint_df$respondent_id),
c("respondent_id", "asylzeugnis", "geschlecht", "herkunftsland",
"alter", "fruehere_beschaeftigung", "schutzbeduerftigkeit",
"migrationsgrund", "religion", "sprachkenntnisse")]
prefs <- make_preferences(pref_dat, id = ~ respondent_id, type = "multilevel")
# ── 2. Estimate EAPNS under both assumptions ─────────────────────────
res <- cj_apns(
chosen ~ asylzeugnis + geschlecht + herkunftsland + alter + fruehere_beschaeftigung +
schutzbeduerftigkeit + migrationsgrund + religion + sprachkenntnisse,
data      = conjoint_df,
id        = ~ respondent_id,
assumption = "both",
preferences = prefs,
se         = "parametric",
B          = 500
)
# View results
summary(res)
# View results
summary(res)
# View results
res
